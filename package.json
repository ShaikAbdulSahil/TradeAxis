{
  "name": "trade-axis-server",
  "version": "1.0.0",
  "description": "TradeAxis MT5 Clone - Virtual Trading Platform",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:user": "nest build user-service",
    "build:market": "nest build market-data-service",
    "build:orders": "nest build order-service",
    "build:all": "nest build user-service && nest build market-data-service && nest build order-service",
    "start:user": "nest start user-service --watch",
    "start:market": "nest start market-data-service --watch",
    "start:orders": "nest start order-service --watch",
    "start:user:prod": "node dist/apps/user-service/main",
    "start:market:prod": "node dist/apps/market-data-service/main",
    "start:orders:prod": "node dist/apps/order-service/main",
    "start:dev": "concurrently \"npm run start:user\" \"npm run start:market\" \"npm run start:orders\"",
    "migration:run": "ts-node migrations/run.ts",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.13",
    "@nestjs/websockets": "^11.1.13",
    "@nestjs/bullmq": "^11.0.0",
    "bullmq": "^5.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "concurrently": "^9.0.0",
    "dotenv": "^16.4.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.0",
    "otplib": "^12.0.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "smartapi-javascript": "^1.0.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}